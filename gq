#!/usr/bin/env python3
"""gq — GPU Task Queue: run shell commands when your GPU is free."""

import argparse
import curses
import datetime
import fcntl
import json
import os
import secrets
import signal
import subprocess
import sys
import time
from contextlib import contextmanager
from pathlib import Path
from typing import Optional

QUEUE_DIR = Path.home() / ".gpu-queue"
QUEUE_FILE = QUEUE_DIR / "queue.json"
STATE_FILE = QUEUE_DIR / "state.json"
LOG_DIR = QUEUE_DIR / "logs"


_TOTAL_CARDS = None  # type: Optional[int]


def _total_cards() -> int:
    """Count GPUs via nvidia-smi -L. Cached after first call."""
    global _TOTAL_CARDS
    if _TOTAL_CARDS is not None:
        return _TOTAL_CARDS
    try:
        result = subprocess.run(
            ["nvidia-smi", "-L"],
            capture_output=True, text=True, timeout=10
        )
        # Each GPU is one line: "GPU 0: NVIDIA GeForce ..."
        _TOTAL_CARDS = sum(1 for line in result.stdout.splitlines()
                           if line.startswith("GPU "))
        if _TOTAL_CARDS == 0:
            _TOTAL_CARDS = 1  # fallback so idle math doesn't divide weirdly
    except (FileNotFoundError, subprocess.TimeoutExpired):
        _TOTAL_CARDS = 1
    return _TOTAL_CARDS


def busy_cards() -> set:
    """Return the set of physical GPU indices with a compute (type=C) process
    owned by the current user. Graphics (type=G) and other users' processes
    do not count. On nvidia-smi failure/timeout, returns ALL card indices
    (safe default: daemon treats all as busy -> no launch).
    """
    uid = os.getuid()
    total = _total_cards()
    try:
        result = subprocess.run(
            ["nvidia-smi", "pmon", "-s", "um", "-c", "1"],
            capture_output=True, text=True, timeout=10
        )
    except FileNotFoundError:
        print("[gq] ERROR: nvidia-smi not found. Is the NVIDIA driver installed?",
              file=sys.stderr)
        sys.exit(1)
    except subprocess.TimeoutExpired:
        print("[gq] WARNING: nvidia-smi timed out, treating all GPUs as busy.",
              file=sys.stderr)
        return set(range(total))

    if result.returncode != 0:
        print(f"[gq] WARNING: nvidia-smi failed (exit {result.returncode}), "
              "treating all GPUs as busy.", file=sys.stderr)
        return set(range(total))

    busy = set()
    for line in result.stdout.splitlines():
        if line.startswith("#") or not line.strip():
            continue
        parts = line.split()
        if len(parts) < 3:
            continue
        if parts[2] != "C":          # skip Graphics (G)
            continue
        try:
            gpu = int(parts[0])
            pid = int(parts[1])
            if os.stat(f"/proc/{pid}").st_uid == uid:
                busy.add(gpu)
        except (ValueError, FileNotFoundError, PermissionError):
            continue
    return busy


def _gpu_utilization() -> dict:
    """Return {gpu_index: utilization_percent} via nvidia-smi.

    Queries `nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits`;
    line i corresponds to GPU i. On any failure (missing binary, timeout, bad
    output) returns {} — callers degrade to binary busy/free coloring using
    `busy_cards()`.
    """
    try:
        result = subprocess.run(
            ["nvidia-smi", "--query-gpu=utilization.gpu",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=10
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return {}
    if result.returncode != 0:
        return {}
    out = {}
    for i, line in enumerate(result.stdout.splitlines()):
        line = line.strip()
        if not line:
            continue
        try:
            out[i] = int(line)
        except ValueError:
            continue
    return out


def _pick_idle(idle: set, n: int) -> list:
    """Pick n idle card indices (lowest indices first)."""
    return sorted(idle)[:n]


def _lock_and_read(path: Path, default):
    """Read JSON from path with exclusive lock. Returns default on missing/corrupt."""
    path.touch(exist_ok=True)
    with open(path, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            content = f.read().strip()
            return json.loads(content) if content else default
        except (UnicodeDecodeError, ValueError):
            print(f"[gq] WARNING: {path.name} corrupted, resetting.", file=sys.stderr)
            return default
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


def _lock_and_write(path: Path, data) -> None:
    """Write JSON to path with exclusive lock."""
    path.touch(exist_ok=True)
    with open(path, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            f.seek(0)
            f.write(json.dumps(data, indent=2))
            f.truncate()
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


@contextmanager
def _locked_queue():
    """Hold the lock across a read-modify-write on queue.json.

    Yields the queue list; mutations made in-place are persisted on exit.
    The fcntl lock is held for the whole RMW, so concurrent writers cannot
    lose jobs by interleaving read/write.
    """
    QUEUE_FILE.touch(exist_ok=True)
    with open(QUEUE_FILE, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            content = f.read().strip()
            try:
                q = json.loads(content) if content else []
            except (UnicodeDecodeError, ValueError):
                print("[gq] WARNING: queue.json corrupted, resetting.",
                      file=sys.stderr)
                q = []
            if not isinstance(q, list):
                print("[gq] WARNING: queue.json corrupted (non-list), resetting.",
                      file=sys.stderr)
                q = []
            yield q
            f.seek(0)
            f.write(json.dumps(q, indent=2))
            f.truncate()
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


def read_queue() -> list:
    q = _lock_and_read(QUEUE_FILE, [])
    if not isinstance(q, list):
        print("[gq] WARNING: queue.json corrupted (non-list), resetting.",
              file=sys.stderr)
        return []
    return q


def write_queue(jobs: list) -> None:
    _lock_and_write(QUEUE_FILE, jobs)


def read_state() -> dict:
    default = {"daemon_pid": None, "running": {}}
    state = _lock_and_read(STATE_FILE, default)
    if not isinstance(state, dict):
        print("[gq] WARNING: state.json corrupted (non-object), resetting.", file=sys.stderr)
        return dict(default)
    running = state.get("running")
    # New shape: running is a dict keyed by job id (possibly empty).
    # Old shape: running was None or a single job dict with "id"/"pid". Migrate
    # those to {} so the dict-keyed model never sees a stale single-job entry.
    # Heuristic: a single-job dict has "id" and "pid" keys whose values are NOT
    # dicts; a dict-of-jobs has dict values (or is empty).
    if running is None or (isinstance(running, dict) and "id" in running and "pid" in running
                           and not any(isinstance(v, dict) for v in running.values())):
        state["running"] = {}
    elif not isinstance(running, dict):
        state["running"] = {}
    # Ensure required keys exist even if file had partial data
    return {**default, **state}


def write_state(state: dict) -> None:
    _lock_and_write(STATE_FILE, state)


def _make_job(cmd: str, cwd: str, n: int = 1) -> dict:
    return {
        "id": secrets.token_hex(2),
        "cmd": cmd,
        "cwd": cwd,
        "added_at": datetime.datetime.now().isoformat(timespec="seconds"),
        # Snapshot the caller's environment so the daemon can re-create it at
        # execution time. Popen(env=...) is a full replacement, not a merge, so
        # the entire dict must be stored (conda/venv activation rewrites PATH and
        # sets many CONDA_* / VIRTUAL_ENV vars that a cherry-pick would drop).
        "env": dict(os.environ),
        "n": n,
    }


def cmd_add(args) -> None:
    n = args.gpus if args.gpus is not None else 1
    job = _make_job(args.command, os.getcwd(), n=n)
    with _locked_queue() as q:
        q.append(job)
    if args.gpus is None:
        print(f"[gq] no --gpus given, running as single-card job")
    print(f"[gq] added job {job['id']}: {args.command}")


def _env_name(job: dict) -> str:
    """Return a short human-readable name for the job's captured environment.

    Prefers CONDA_DEFAULT_ENV (set by conda activate), else the basename of
    VIRTUAL_ENV (set by venv/activate). Returns "" if neither is present.
    Reads from the job's captured env snapshot, NOT os.environ — the daemon
    runs in a different environment than the shell that added the job.
    """
    env = job.get("env") or {}
    if env.get("CONDA_DEFAULT_ENV"):
        return env["CONDA_DEFAULT_ENV"]
    venv = env.get("VIRTUAL_ENV")
    if venv:
        return os.path.basename(venv)
    return ""


def cmd_list(args) -> None:
    state = read_state()
    queue = read_queue()

    # Running jobs (now potentially multiple)
    running = state.get("running") or {}
    if running:
        print("[gq] running:")
        for rid, r in running.items():
            try:
                started = datetime.datetime.fromisoformat(r["started_at"])
                elapsed = str(datetime.datetime.now() - started).split(".")[0]
            except (KeyError, ValueError, TypeError):
                elapsed = "unknown"
            cards = ",".join(str(c) for c in r.get("cards", []))
            ename = _env_name(r)
            suffix = f"  [{ename}]" if ename else ""
            gpu = f"  GPU {cards}" if cards else ""
            print(f"  {rid}  {r['cmd']}{gpu}   started {elapsed} ago{suffix}")
    else:
        print("[gq] running: none")

    # Pending queue
    n = len(queue)
    label = f"{n} job" + ("s" if n != 1 else "")
    print(f"\n[gq] queue ({label}):")
    if not queue:
        print("  (empty)")
    for i, job in enumerate(queue, 1):
        ename = _env_name(job)
        suffix = f"  [{ename}]" if ename else ""
        print(f"  #{i}  {job['id']}  {job['cmd']}{suffix}")

    # Daemon status
    dpid = state.get("daemon_pid")
    if dpid:
        try:
            os.kill(dpid, 0)
            print(f"\n[gq] daemon: running (pid {dpid})")
        except (ProcessLookupError, TypeError):
            print(f"\n[gq] daemon: stale pid {dpid} (not running)")
    else:
        print("\n[gq] daemon: not running — start with: gq watch")


def cmd_cancel(args) -> None:
    job_id = args.job_id

    # Check if it's a running job (read_state uses its own lock — do NOT
    # hold the queue lock while checking state). running is a dict keyed by
    # job id; refuse to cancel any job that is currently running.
    state = read_state()
    running = state.get("running") or {}
    match = next((rid for rid in running if rid.startswith(job_id)), None)
    if match:
        print(f"[gq] job {match} is currently running. "
              "Use 'gq stop' to stop it (the daemon stays alive).")
        return

    with _locked_queue() as q:
        matches = [j for j in q if j["id"].startswith(job_id)]

        if not matches:
            print(f"[gq] job '{job_id}' not found in queue.")
            return
        if len(matches) > 1:
            ids = ", ".join(j["id"] for j in matches)
            print(f"[gq] ambiguous prefix '{job_id}' matches: {ids}. Be more specific.")
            return

        target = matches[0]
        # Mutate the yielded list in place so the RMW persists.
        q[:] = [j for j in q if j["id"] != target["id"]]
    print(f"[gq] cancelled job {target['id']}: {target['cmd']}")


def cmd_clear(args) -> None:
    with _locked_queue() as q:
        n = len(q)
        q[:] = []
    print(f"[gq] cleared {n} pending job{'s' if n != 1 else ''}.")


def _kill_pid_and_children(pid: int) -> None:
    """SIGKILL a pid AND its direct children — WITHOUT os.killpg (which could
    hit gq's own group if setsid didn't take effect). Used as the safe fallback
    when the three-way killpg guard declines to fire: kill the shell pid, then
    walk /proc to find children whose PPID == pid and kill each individually.
    This deliberately does NOT recurse beyond one level and does NOT use
    killpg — leaving deeper descendants orphaned is far better than risking
    gq's session. /proc/<pid>/stat format is "pid (comm) state ppid ...";
    `comm` may contain spaces and parens, so split from the LAST ')'.
    """
    try:
        os.kill(pid, signal.SIGKILL)
    except (ProcessLookupError, OSError):
        return
    # Enumerate children via /proc/*/stat: kill any whose PPID == pid.
    import os as _os
    try:
        entries = _os.listdir("/proc")
    except OSError:
        return
    for name in entries:
        if not name.isdigit():
            continue
        try:
            with open(f"/proc/{name}/stat", "r") as f:
                stat = f.read()
        except (FileNotFoundError, ProcessLookupError, OSError):
            continue
        # stat = "pid (comm) state ppid ..." — comm may contain spaces/parens,
        # so split on the last ')' and parse the remainder.
        rparen = stat.rfind(")")
        if rparen < 0:
            continue
        rest = stat[rparen + 2:].split()  # "state ppid ..."
        if len(rest) < 2:
            continue
        try:
            ppid = int(rest[1])
        except ValueError:
            continue
        if ppid == pid:
            try:
                _os.kill(int(name), signal.SIGKILL)
            except (ProcessLookupError, OSError):
                pass


def cmd_stop(args) -> None:
    """Stop a specific running job by ID (SIGKILL its process group).

    With multiple jobs running concurrently, an ID is required. The daemon
    stays alive and reaps the killed job, releasing its cards.
    """
    state = read_state()
    running = state.get("running") or {}
    job_id = args.job_id

    matches = [jid for jid in running if jid.startswith(job_id)]
    if not matches:
        print(f"[gq] no running job matches '{job_id}'.")
        return
    if len(matches) > 1:
        ids = ", ".join(matches)
        print(f"[gq] ambiguous prefix '{job_id}' matches: {ids}. Be more specific.")
        return

    target_id = matches[0]
    rpid = running[target_id].get("pid")
    if not rpid:
        print(f"[gq] job {target_id} has no pid yet (not fully started).")
        return
    # SAFETY: jobs are launched with start_new_session=True so the job's process
    # group SHOULD equal its pid. But os.setsid/start_new_session can fail to
    # take effect (this exact bug once SIGKILLed the user's whole session when
    # the child shared gq's group). Verify the group is the child's OWN and is
    # NOT gq's group before killpg; otherwise kill only the job pid, never gq's
    # group. (See the matching guard in _run_embedded_bash's finally block.)
    try:
        child_pgid = os.getpgid(rpid)
    except (ProcessLookupError, OSError):
        print(f"[gq] job {target_id} already finished (pid {rpid} not found).")
        return
    except PermissionError as exc:
        print(f"[gq] ERROR: cannot stop job {target_id} (pid {rpid}): {exc}")
        return
    my_pgid = os.getpgid(0)
    killed_group = False
    if (child_pgid == rpid and child_pgid != my_pgid and child_pgid > 0):
        try:
            os.killpg(child_pgid, signal.SIGKILL)
            killed_group = True
        except (ProcessLookupError, OSError):
            pass
    if not killed_group:
        # Groups coincide or look unsafe — kill the job pid AND its direct
        # children (the real command, spawned by /bin/sh -c), but WITHOUT
        # killpg so gq's own group is never hit. _kill_pid_and_children walks
        # /proc for PPID==pid children.
        _kill_pid_and_children(rpid)
    print(f"[gq] stopped job {target_id} (pid {rpid}).")


def _format_elapsed(seconds: float) -> str:
    """Format seconds as HH:MM:SS."""
    s = int(seconds)
    return f"{s // 3600:02d}:{(s % 3600) // 60:02d}:{s % 60:02d}"


def _build_rows(state: dict, queue: list) -> list:
    """Build the TUI operations list from current state + queue. Pure (no curses).

    Row order: Add, then one Stop + one Open-log per running job, then one
    Cancel per queued job, then Clear, Quit. Each row:
      {"kind": "op"|"job", "label": str, "action": str, "job_id": str|None}
    """
    rows = []
    rows.append({"kind": "op", "label": "Add job",
                 "action": "add", "job_id": None})
    running = state.get("running") or {}
    for rid, r in running.items():
        cards = ",".join(str(c) for c in r.get("cards", []))
        rows.append({"kind": "job", "label": f"Stop: {rid}  ({r.get('cmd','')} GPU {cards})",
                     "action": "stop", "job_id": rid})
    for rid, r in running.items():
        rows.append({"kind": "job", "label": f"Open log: {rid}",
                     "action": "open_log", "job_id": rid})
    for i, job in enumerate(queue, 1):
        rows.append({"kind": "job",
                     "label": f"Cancel: #{i} {job['id']}  ({job.get('cmd','')})",
                     "action": "cancel", "job_id": job["id"]})
    rows.append({"kind": "op", "label": "Clear queue",
                 "action": "clear", "job_id": None})
    rows.append({"kind": "op", "label": "Quit",
                 "action": "quit", "job_id": None})
    return rows


def _launch_job(job: dict, cards: list) -> Optional[subprocess.Popen]:
    """Launch a job on the given cards (non-blocking). Returns the Popen, or
    None on launch failure. Injects CUDA_VISIBLE_DEVICES into the job's env.
    Task stdout/stderr is redirected to ~/.gpu-queue/logs/<id>.log (the watch
    terminal prints only summary lines; the TUI can display the log tail).
    """
    cwd = job["cwd"]
    if not os.path.isdir(cwd):
        print(f"[gq] WARNING: cwd '{cwd}' does not exist, skipping job {job['id']}.")
        return None
    env = dict(job.get("env") or {})
    env["CUDA_VISIBLE_DEVICES"] = ",".join(str(c) for c in cards)
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    log_path = LOG_DIR / f"{job['id']}.log"
    try:
        log_f = open(log_path, "w")
    except OSError as exc:
        print(f"[gq] ERROR opening log {log_path}: {exc}")
        return None
    print(f"[gq] >>> {job['cmd']}   (GPU {','.join(str(c) for c in cards)})   log: {log_path}")
    try:
        # TODO(treatment): after Popen, verify os.getpgid(proc.pid) == proc.pid
        # (start_new_session took effect). If not, the killpg guards in
        # cmd_stop / _force_kill_all_running / crash-recovery will correctly
        # decline to killpg (falling back to _kill_pid_and_children), so the
        # session is safe — but the job's group then can't be reaped as a unit.
        # A future hardening could warn + re-launch without setsid failure.
        proc = subprocess.Popen(job["cmd"], shell=True, cwd=cwd,
                                start_new_session=True, env=env,
                                stdout=log_f, stderr=log_f)
    except Exception as exc:
        log_f.close()
        print(f"[gq] ERROR running job {job['id']}: {exc}")
        return None
    # Popen sets self.stdout = None when stdout is a file (not PIPE), so retain
    # the handle ourselves for the daemon to flush/close when the job is reaped
    # (see _daemon_loop reap block). NOTE: log_f is intentionally not closed
    # here — the child writes to its fd asynchronously.
    proc.stdout = log_f
    return proc


# Module-level state for the concurrent loop. _shutdown_requested lets the
# SIGINT handler ask the loop to stop; _running holds live jobs so the handler
# can force-kill ALL of them on a second Ctrl-C. _running is module-level so it
# persists across loop iterations (the loop does NOT reset it on entry).
_shutdown_requested = False
_running = {}  # type: dict  # {id: {"proc": Popen, "job": dict, "cards": [int], "start": float}}


def _force_kill_all_running() -> None:
    """SIGKILL every running job's process group (the second-Ctrl-C path).

    shell=True spawns /bin/sh -c <cmd>, so killing only the shell pid would
    orphan the real command; SIGKILL each group via os.killpg. Extracted to a
    module-level helper so it is unit-testable without delivering real signals.
    """
    # SAFETY: same guard as cmd_stop / _run_embedded_bash — only killpg a group
    # we've confirmed is the job's OWN (start_new_session made pgid == pid) and
    # NOT gq's own group. If setsid didn't take effect, fall back to killing the
    # job pid only. Never SIGKILL gq's group (would kill the terminal/tmux/all
    # sibling processes — a real incident this code path previously caused).
    my_pgid = os.getpgid(0)
    for rid, info in list(_running.items()):
        pid = info["proc"].pid
        try:
            child_pgid = os.getpgid(pid)
        except (ProcessLookupError, OSError):
            continue
        if (child_pgid == pid and child_pgid != my_pgid and child_pgid > 0):
            try:
                os.killpg(child_pgid, signal.SIGKILL)
                continue
            except (ProcessLookupError, OSError):
                pass
        # Groups coincide or look unsafe — kill the job pid AND its direct
        # children, WITHOUT killpg so gq's own group is never hit.
        _kill_pid_and_children(pid)


def _daemon_loop(poll_interval: int) -> None:
    """Concurrent multi-GPU polling loop. Launches the queue head when enough
    idle cards exist; reaps finished jobs each cycle. Exits on shutdown."""
    global _shutdown_requested
    _shutdown_requested = False

    ctrl_c_count = [0]

    def _handle_sigint(sig, frame):
        ctrl_c_count[0] += 1
        if ctrl_c_count[0] == 1:
            print("\n[gq] Ctrl-C received. Waiting for running jobs to finish. "
                  "Press Ctrl-C again to force-kill all.", file=sys.stderr)
            _shutdown_requested = True
        else:
            # Second Ctrl-C: SIGKILL ALL running jobs' process groups.
            _force_kill_all_running()
            sys.exit(0)

    old_handler = signal.signal(signal.SIGINT, _handle_sigint)
    try:
        # Keep looping while not shutting down OR there are still live jobs to
        # reap. After the first Ctrl-C sets _shutdown_requested, the loop drains
        # _running (reaping finished jobs) but does NOT launch new ones — the
        # launch block below is gated on `not _shutdown_requested`. Only when
        # every live job has been reaped does the loop exit, so graceful Ctrl-C
        # no longer orphans jobs that are still running on the GPU.
        while not _shutdown_requested or _running:
            # 1. Reap finished jobs (always, even after shutdown requested).
            for rid in list(_running.keys()):
                info = _running[rid]
                code = info["proc"].poll()
                if code is not None:
                    elapsed = _format_elapsed(time.monotonic() - info["start"])
                    if code == 0:
                        print(f"[gq] <<< job {rid} DONE (exit=0) in {elapsed}")
                    else:
                        print(f"[gq] <<< job {rid} FAILED (exit={code}) in {elapsed}")
                    # Flush/close the per-job log file (retained on proc.stdout by
                    # _launch_job). Guarded: legacy/fake procs may lack stdout.
                    _logf = getattr(info["proc"], "stdout", None)
                    if _logf is not None:
                        _logf.close()
                    del _running[rid]
                    _state = read_state()
                    _state.setdefault("running", {}).pop(rid, None)
                    write_state(_state)

            # 2. Launch as many queued jobs as fit the idle cards this cycle
            # (NOT just the head) so concurrent multi-GPU jobs start together
            # instead of being staggered by poll_interval seconds each. After
            # graceful shutdown is requested, skip launching so no new jobs
            # start while we drain the live ones.
            if not _shutdown_requested:
                total = _total_cards()
                busy = busy_cards()
                # Cards already assigned to running jobs are not idle even if
                # nvidia-smi hasn't caught up.
                assigned = set()
                for info in _running.values():
                    assigned.update(info["cards"])
                idle = set(range(total)) - busy - assigned

                # Launch in a loop: re-derive idle (subtracting each just-launched
                # job's cards) so the next job gets DIFFERENT cards. Strict FIFO:
                # if the head doesn't fit, break — don't skip to smaller jobs.
                while True:
                    with _locked_queue() as q:
                        if not q:
                            break
                        head = q[0]
                        n = head.get("n", 1)
                        if len(idle) < n:
                            break  # head doesn't fit; don't skip (strict FIFO)
                        q.pop(0)
                    cards = _pick_idle(idle, n)
                    proc = _launch_job(head, cards)
                    if proc is not None:
                        head["started_at"] = datetime.datetime.now().isoformat(timespec="seconds")
                        _running[head["id"]] = {"proc": proc, "job": head,
                                                "cards": cards, "start": time.monotonic()}
                        _state = read_state()
                        _state.setdefault("running", {})[head["id"]] = {
                            **head, "cards": cards, "pid": proc.pid
                        }
                        write_state(_state)
                        print(f"\n[gq] GPU idle — starting job {head['id']} on "
                              f"GPU {','.join(str(c) for c in cards)}")
                        # Reserve these cards so the next iteration picks
                        # different ones.
                        idle = idle - set(cards)
                    else:
                        # launch failed (bad cwd) — job already popped; don't
                        # loop forever trying to re-launch it.
                        break

            time.sleep(poll_interval)
    finally:
        signal.signal(signal.SIGINT, old_handler)

    print("[gq] daemon exiting.")


def cmd_watch(args) -> None:
    # Check for existing daemon
    state = read_state()
    dpid = state.get("daemon_pid")
    if dpid:
        try:
            os.kill(dpid, 0)
            print(f"[gq] daemon already running (pid {dpid}). Exiting.")
            return
        except ProcessLookupError:
            pass  # stale pid — proceed

    # Clear stale running entries on startup (crash recovery). running is now a
    # dict keyed by job id; for each entry, if the recorded pid is still alive
    # the previous daemon was killed mid-job and the orphan is still on the GPU
    # — kill its process group. Stale (dead) entries are just cleared.
    running = state.get("running") or {}
    if running:
        for rid, r in list(running.items()):
            rpid = r.get("pid")
            alive = False
            if rpid:
                try:
                    # Check liveness of the pid directly (NOT via killpg(group,0),
                    # which could touch an unrelated group if the pid was recycled).
                    os.kill(rpid, 0)
                    alive = True
                except ProcessLookupError:
                    pass
                except (TypeError, PermissionError, OSError):
                    pass  # pid None/non-int or not ours — treat as stale
            if alive:
                # SAFETY: rpid comes from a PREVIOUS daemon's state file, so it may
                # have been recycled to an unrelated process (terminal/tmux/etc).
                # Only killpg if the group is the pid's OWN (pgid == pid, i.e. it's
                # still a session leader as start_new_session made it) and is NOT
                # gq's own group. Otherwise DO NOT kill — warn the user instead,
                # since killing a recycled pid's group could SIGKILL the session.
                my_pgid = os.getpgid(0)
                safe_to_killpg = False
                try:
                    child_pgid = os.getpgid(rpid)
                    safe_to_killpg = (child_pgid == rpid
                                      and child_pgid != my_pgid
                                      and child_pgid > 0)
                except (ProcessLookupError, OSError):
                    safe_to_killpg = False
                if safe_to_killpg:
                    print(f"[gq] WARNING: orphaned job {rid} (pid {rpid}) still running "
                          "from a previous daemon crash; killing its process group.",
                          file=sys.stderr)
                    try:
                        os.killpg(child_pgid, signal.SIGKILL)
                    except (ProcessLookupError, OSError):
                        pass
                else:
                    print(f"[gq] WARNING: orphaned job {rid} (pid {rpid}) is alive but "
                          "its process group can't be confirmed safe (pid may have been "
                          "recycled). NOT auto-killing — inspect pid {rpid} manually.",
                          file=sys.stderr)
            else:
                print(f"[gq] WARNING: stale running entry for job {rid} "
                      "cleared (process no longer running).", file=sys.stderr)
        state["running"] = {}

    # Register this daemon
    state["daemon_pid"] = os.getpid()
    write_state(state)

    print(f"[gq] daemon started (pid {os.getpid()}), polling every {args.poll}s")
    print("[gq] Ctrl-C to stop gracefully. Press twice to force-kill.\n")

    try:
        _daemon_loop(args.poll)
    finally:
        # Clear only the daemon_pid. Do NOT blanket-clear state["running"]:
        # on a graceful exit the loop has already drained _running to empty
        # (each reaped job is popped from state["running"] as it finishes), so
        # state["running"] is already {}. On a force-kill (2nd Ctrl-C),
        # _force_kill_all_running SIGKILLed the process groups but they may
        # not have been reaped yet — leaving state["running"] lets the next
        # `gq watch` reap them via crash-recovery (live orphans are killed,
        # dead entries are cleared as stale). Clearing here would orphan jobs
        # that are still alive on the GPU.
        s = read_state()
        s["daemon_pid"] = None
        write_state(s)


# ---------------------------------------------------------------------------
# TUI (curses): render panel + per-GPU bars + main loop
# ---------------------------------------------------------------------------

_COLORS_INITED = False


def _init_colors():
    """Initialize curses color pairs once. Idempotent. No-op on colorless
    terminals (curses.has_colors() is False) — renderers fall back to
    A_NORMAL/A_REVERSE which need no color pair."""
    global _COLORS_INITED
    if _COLORS_INITED:
        return
    if curses.has_colors():
        curses.init_pair(1, curses.COLOR_GREEN, curses.COLOR_BLACK)   # idle / <50%
        curses.init_pair(2, curses.COLOR_YELLOW, curses.COLOR_BLACK)  # 50-80%
        curses.init_pair(3, curses.COLOR_RED, curses.COLOR_BLACK)     # >80% / busy
        curses.init_pair(4, curses.COLOR_CYAN, curses.COLOR_BLACK)    # hints
    _COLORS_INITED = True


def _util_bar(percent: int, width: int = 12) -> str:
    """Build a fixed-width utilization bar from a percent (0-100).

    Filled cells use `█`, the single fractional cell uses a half-block char
    (`▏▎▍▌▋▊▉` for 1/8..7/8), empty cells use `░`.
    """
    percent = max(0, min(100, int(percent)))
    frac = percent / 100.0 * width
    full = int(frac)
    rem = frac - full
    bar = "█" * full
    if rem > 0 and full < width:
        idx = int(round(rem * 8))
        if idx >= 8:
            bar += "█"
        elif idx > 0:
            bar += "▏▎▍▌▋▊▉"[idx - 1]
    bar += "░" * (width - len(bar))
    return bar[:width]


def _safe_addstr(stdscr, y, x, s, attr=curses.A_NORMAL):
    """addstr that never raises: clamps to screen and avoids the bottom-right
    corner cell (writing there raises curses.error on most implementations)."""
    h, w = stdscr.getmaxyx()
    if y < 0 or y >= h or x < 0 or x >= w:
        return
    max_len = w - x
    if y == h - 1:
        max_len -= 1  # bottom-right corner is off-limits
    if max_len <= 0:
        return
    try:
        stdscr.addstr(y, x, str(s)[:max_len], attr)
    except curses.error:
        pass


def _gpu_summary_line(total, busy, nrun, nq):
    """One-line GPU overview for the top bar. Takes pre-read values so the
    caller can share a single nvidia-smi read across the whole render cycle
    (busy_cards / _gpu_utilization are expensive subprocess calls)."""
    clock = datetime.datetime.now().strftime("%H:%M:%S")
    idle = total - len(busy)
    return f" gq  {total} GPUs ({idle} idle)  {nrun} running  {nq} queued   {clock}"


def _render_panel(stdscr, rows, focus, gpu_summary, total, utils, busy, state):
    """Render the TUI: top summary + per-GPU utilization bars + operations
    list + bottom hint. Uses noutrefresh (caller runs doupdate) for flicker-
    free updates. Takes pre-read total/utils/busy/state so the caller does
    ONE nvidia-smi read per cycle (busy_cards + _gpu_utilization), shared
    with _gpu_summary_line — instead of each rendering helper re-querying.
    """
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    _init_colors()
    GREEN, YELLOW, RED, CYAN = 1, 2, 3, 4
    PAD = 4  # left padding so content isn't flush against the edge

    # Top summary line (read-only)
    _safe_addstr(stdscr, 0, PAD, gpu_summary[:w - 1 - PAD],
                 curses.color_pair(CYAN) | curses.A_BOLD)

    # Per-GPU utilization bars (one line per GPU)
    running = state.get("running") or {}
    # Map each card index -> (job_id, running_job_dict) that owns it.
    card_to_job = {}
    for rid, r in running.items():
        for c in r.get("cards", []):
            card_to_job[c] = (rid, r)

    y = 1
    for gpu in range(total):
        if y >= h - 1:
            break
        pct = utils.get(gpu)
        if pct is None:
            # nvidia-smi util unavailable: degrade to binary busy/free.
            pct = 100 if gpu in busy else 0
        if pct < 50:
            color = GREEN
        elif pct <= 80:
            color = YELLOW
        else:
            color = RED
        bar = _util_bar(pct, 12)
        head = f"GPU {gpu:<2d} "
        # Owning job id + cmd snippet + elapsed, if a running job holds this card.
        job_info = ""
        owner = card_to_job.get(gpu)
        if owner is not None:
            rid, r = owner
            cmd = r.get("cmd") or ""
            snippet = cmd if len(cmd) <= 18 else cmd[:17] + "…"
            try:
                started = datetime.datetime.fromisoformat(r["started_at"])
                elapsed = _format_elapsed(
                    (datetime.datetime.now() - started).total_seconds())
            except (KeyError, ValueError, TypeError):
                elapsed = "--:--:--"
            job_info = f"  {rid} {snippet}  {elapsed}"
        elif gpu in busy:
            job_info = "  (busy)"
        _safe_addstr(stdscr, y, PAD, head, curses.A_NORMAL)
        _safe_addstr(stdscr, y, PAD + len(head), bar, curses.color_pair(color))
        rest = f" {pct:>3d}%{job_info}"
        _safe_addstr(stdscr, y, PAD + len(head) + len(bar), rest)
        y += 1

    # Separator between GPU bars and operations list
    if y < h - 1:
        _safe_addstr(stdscr, y, PAD, "-" * (w - 1 - 2 * PAD))
        y += 1

    # Operations list (selectable) — double-spaced (y += 2) for readability
    for i, row in enumerate(rows):
        if y >= h - 1:
            break
        label = row.get("label", "")[:w - 1 - PAD]
        attr = curses.A_REVERSE if i == focus else curses.A_NORMAL
        _safe_addstr(stdscr, y, PAD, label, attr)
        y += 2

    # Bottom hint — context-sensitive: shows guidance for the focused row
    hints = {
        "add": " Enter: open bash, type command, F5 to submit, Esc to cancel ",
        "stop": " Enter: stop this running job (daemon stays alive) ",
        "cancel": " Enter: remove this queued job from the queue ",
        "clear": " Enter: clear all queued jobs (running jobs unaffected) ",
        "open_log": " Enter: view this job's output log tail ",
        "quit": " Enter: exit the TUI (daemon keeps running) ",
    }
    focused_action = rows[focus].get("action", "") if 0 <= focus < len(rows) else ""
    hint = hints.get(focused_action, " ↑↓ select  Enter confirm  q quit ")
    _safe_addstr(stdscr, h - 1, PAD, hint[:w - 1 - PAD],
                 curses.color_pair(CYAN))

    stdscr.noutrefresh()


def _dispatch_action(row: dict) -> bool:
    """Pure dispatch for a TUI row's action (no curses). Returns True if the
    TUI should quit. add/open_log/stop are handled by the curses-aware
    _tui_do_action (they need stdscr or subprocess); _dispatch_action handles
    the state-only ones (quit/cancel/clear) for testability.
    """
    action = row["action"]
    if action == "quit":
        return True
    if action == "cancel":
        # Reuse cmd_cancel's logic by constructing an args-like namespace.
        cmd_cancel(argparse.Namespace(job_id=row["job_id"]))
        return False
    if action == "clear":
        cmd_clear(argparse.Namespace())
        return False
    # add, stop, open_log are curses/subprocess-bound — handled in _tui_do_action
    return False


def _tui_blocking_mode(stdscr):
    """Switch the terminal to blocking input for modal prompts.

    _tui_main sets curses.halfdelay(20) so the main loop refreshes every 2s;
    that makes stdscr.getch() return ERR (-1) on timeout, which would cause
    modal prompt loops to spin/re-poll every 2s (flickery). Disabling cbreak
    clears the halfdelay timer; we then re-enable cbreak for raw key reads.
    Returns nothing — pair with _tui_restore_halfdelay(stdscr).
    """
    curses.nocbreak()  # clears halfdelay; getch now blocks until a real key
    curses.cbreak()    # re-enable raw mode (no line buffering) without timeout


def _tui_restore_halfdelay(stdscr):
    """Restore the 2-second halfdelay tick after a modal returns."""
    curses.halfdelay(20)


def _tui_confirm(stdscr, focus_y, label, msg):
    """y/n confirm drawn INLINE on the focused row, right after its label —
    so the prompt sits next to the operation the user selected, not stranded
    at the screen bottom. Returns True on y.
    """
    h, w = stdscr.getmaxyx()
    if not (0 <= focus_y < h):
        focus_y = h - 2  # fallback to near-bottom if the row is off-screen
    # Clear from end of label to end of line, then write the prompt inline.
    # Label starts at x=4 (PAD), so the prompt x = PAD + len(label) + 1.
    x = min(4 + len(label) + 1, w - 1)
    _safe_addstr(stdscr, focus_y, x, " " * (w - 1 - x))
    prompt = f"  {msg} [y/n]"
    _safe_addstr(stdscr, focus_y, x, prompt[:w - 1 - x],
                 curses.A_REVERSE | curses.A_BOLD)
    stdscr.refresh()
    _tui_blocking_mode(stdscr)
    try:
        while True:
            ch = stdscr.getch()
            if ch in (ord("y"), ord("Y")):
                return True
            if ch in (ord("n"), ord("N"), 27):  # n or Esc
                return False
    finally:
        _tui_restore_halfdelay(stdscr)


def _tui_select_gpus(stdscr):
    """Curses list-select for --gpus in 1..N. Returns the selected int, or 1."""
    n = _total_cards()
    if n <= 0:
        return 1  # degenerate: no GPUs detected — default to single-card
    choices = list(range(1, n + 1))
    focus = 0
    h, w = stdscr.getmaxyx()
    _tui_blocking_mode(stdscr)
    try:
        while True:
            _safe_addstr(stdscr, h - 2, 0, " " * (w - 1))
            line = " --gpus: " + "  ".join(f"[{c}]" if i == focus else f" {c} "
                                           for i, c in enumerate(choices))
            _safe_addstr(stdscr, h - 2, 0, line[:w - 1], curses.A_BOLD)
            ch = stdscr.getch()
            if ch in (curses.KEY_LEFT, ord("h")):
                focus = max(0, focus - 1)
            elif ch in (curses.KEY_RIGHT, ord("l")):
                focus = min(len(choices) - 1, focus + 1)
            elif ch in (curses.KEY_ENTER, 10, 13):
                return choices[focus]
            elif ch == 27:
                return 1  # default on Esc
    finally:
        _tui_restore_halfdelay(stdscr)


def _tui_do_action(stdscr, row, focus) -> bool:
    """Execute a TUI row's action. Returns True if TUI should quit.

    `focus` is the index of the selected row in the operations list; it's
    used to compute the screen y where inline confirm prompts are drawn.
    """
    action = row["action"]
    if action == "quit":
        return True
    # Screen y of the focused operations-list row: 1 (top status) + N GPU
    # bars + 1 separator + focus * 2 (double-spaced). Used to draw confirm
    # prompts inline. PAD offset is applied where the prompt x is computed.
    focus_y = 1 + _total_cards() + 1 + focus * 2
    label = row.get("label", "")
    if action == "add":
        # Dialog origin: the Add row's screen y, x after label + padding.
        captured = _run_embedded_bash(stdscr, oy=focus_y, ox=4 + len("Add job") + 2)
        if not captured:
            return False  # user cancelled in bash
        n = _tui_select_gpus(stdscr)
        job = _make_job(captured["cmd"], captured["cwd"], n=n)
        # Use the bash-captured env instead of the snapshot (bash may have
        # activated a conda env during composition). Strip READLINE_LINE /
        # READLINE_POINT first — these are set transiently by bash's `bind -x`
        # during F5 capture and must not leak into the job's stored environment.
        env = {k: v for k, v in captured["env"].items()
               if k not in ("READLINE_LINE", "READLINE_POINT")}
        job["env"] = env
        with _locked_queue() as q:
            q.append(job)
        return False
    if action == "stop":
        if _tui_confirm(stdscr, focus_y, label, f"Stop {row['job_id']}?"):
            cmd_stop(argparse.Namespace(job_id=row["job_id"]))
        return False
    if action == "cancel":
        if _tui_confirm(stdscr, focus_y, label, f"Cancel {row['job_id']}?"):
            _dispatch_action(row)
        return False
    if action == "clear":
        if _tui_confirm(stdscr, focus_y, label, "Clear all queued jobs?"):
            _dispatch_action(row)
        return False
    if action == "open_log":
        log_path = LOG_DIR / f"{row['job_id']}.log"
        _tui_show_log(stdscr, log_path)
        return False
    return False


def _tui_show_log(stdscr, log_path):
    """Show the tail of a job's log file; any key returns."""
    h, w = stdscr.getmaxyx()
    stdscr.erase()
    try:
        text = Path(log_path).read_text(errors="replace")
    except OSError:
        text = "(no log yet)"
    lines = text.splitlines()[-(h - 2):]
    _safe_addstr(stdscr, 0, 0, f" log: {log_path}"[:w - 1], curses.A_BOLD)
    for i, ln in enumerate(lines, 1):
        if i >= h - 1:
            break
        _safe_addstr(stdscr, i, 0, ln[:w - 1])
    _safe_addstr(stdscr, h - 1, 0, " any key to return "[:w - 1], curses.color_pair(4))
    _tui_blocking_mode(stdscr)
    try:
        stdscr.getch()
    finally:
        _tui_restore_halfdelay(stdscr)


def _tui_main(stdscr):
    """Curses TUI main loop. stdscr is provided by curses.wrapper."""
    curses.curs_set(0)  # hide cursor
    stdscr.keypad(True)
    curses.halfdelay(20)  # 2-second refresh tick; keys return immediately
    focus = 0
    # Cache the expensive nvidia-smi reads (busy_cards / _gpu_utilization) and
    # only REFRESH them on the halfdelay timeout (every 2s), NOT on every
    # keystroke. Before this, each keypress waited for 2 nvidia-smi subprocess
    # calls (up to ~10s each on a hung driver) before the next key was read —
    # making the TUI feel laggy. Now keys respond instantly from cache; the
    # GPU bars update at most 2s late, which is fine for a status display.
    # state/queue are cheap (file reads) so they're read every cycle.
    cached_total = _total_cards()
    cached_busy = busy_cards()
    cached_utils = _gpu_utilization()
    while True:
        state = read_state()
        queue = read_queue()
        rows = _build_rows(state, queue)
        if focus >= len(rows):
            focus = max(0, len(rows) - 1)
        nrun = len(state.get("running") or {})
        summary = _gpu_summary_line(cached_total, cached_busy, nrun, len(queue))
        _render_panel(stdscr, rows, focus, summary, cached_total, cached_utils,
                      cached_busy, state)
        curses.doupdate()
        ch = stdscr.getch()
        if ch == -1:
            # halfdelay timeout — refresh the expensive nvidia-smi cache.
            cached_busy = busy_cards()
            cached_utils = _gpu_utilization()
            continue
        if ch in (curses.KEY_UP, ord("k")):
            focus = max(0, focus - 1)
        elif ch in (curses.KEY_DOWN, ord("j")):
            focus = min(len(rows) - 1, focus + 1)
        elif ch == ord("q"):
            break
        elif ch in (curses.KEY_ENTER, 10, 13):
            if rows and 0 <= focus < len(rows):
                done = _tui_do_action(stdscr, rows[focus], focus)
                if done:
                    break
        # any other key: just re-render on next cycle (cheap, from cache)


def _key_to_bytes(ch: int):
    """Map a curses key code to the bytes bash/readline expect, or None if
    the key is reserved for gq (F5 submit, Esc cancel). Enter is NOT reserved
    — it executes the command in bash (for cd/source/test-run), and F5 submits
    the current command line to the gq queue without executing."""
    import curses as _c
    reserved = {_c.KEY_F5, 27}  # F5, Esc — gq handles these
    if ch in reserved:
        return None
    arrow = {_c.KEY_UP: b"\x1b[A", _c.KEY_DOWN: b"\x1b[B",
             _c.KEY_RIGHT: b"\x1b[C", _c.KEY_LEFT: b"\x1b[D"}
    if ch in arrow:
        return arrow[ch]
    if ch == _c.KEY_ENTER:
        return b"\r"
    if ch == _c.KEY_BACKSPACE or ch == 127 or ch == 8:
        return b"\x7f"
    if 0 <= ch < 256:
        return bytes([ch])   # printable + Ctrl combos (Ctrl-C=3, Ctrl-D=4, ...)
    return None


def _render_pyte_to_dialog(stdscr, screen, oy, ox, dh, dw):
    """Render a pyte.Screen's buffer into curses at origin (oy, ox) within a
    dh x dw region, preserving per-character colors (so the bash prompt shows
    green, etc.). Reads screen.buffer (dict[(y,x)] -> Char with fg/bg/bold/...)
    and groups consecutive chars with the same attributes into one addstr call.
    Moves the cursor to pyte's cursor position (so the user sees where typing
    will appear). Best-effort: curses errors on edge cells are swallowed.
    """
    import curses as _c
    # Map pyte color names -> curses color pair numbers (1=green, 2=yellow,
    # 3=red, 4=cyan, as initialized by _init_colors). Default = no color.
    fg_to_pair = {"green": 1, "yellow": 2, "red": 3, "cyan": 4,
                  "blue": 4, "magenta": 4}
    buffer = screen.buffer
    for y in range(dh):
        x = 0
        while x < dw:
            # Collect a run of chars with the same attributes.
            ch = buffer[y][x] if y in buffer and x in buffer[y] else None
            if ch is None:
                # No char at this position — write a space and advance.
                x += 1
                continue
            run_attr = _c.A_NORMAL
            if getattr(ch, "bold", False):
                run_attr |= _c.A_BOLD
            if getattr(ch, "reverse", False):
                run_attr |= _c.A_REVERSE
            if getattr(ch, "underscore", False):
                run_attr |= _c.A_UNDERLINE
            fg = getattr(ch, "fg", "default")
            pair = fg_to_pair.get(fg, 0)  # 0 = default (no color pair)
            if pair:
                run_attr |= _c.color_pair(pair)
            # Gather consecutive chars with the same fg/bold/reverse/underscore.
            run_chars = []
            while x < dw:
                c = buffer[y][x] if y in buffer and x in buffer[y] else None
                if c is None:
                    break
                c_fg = getattr(c, "fg", "default")
                c_attr = (_c.A_BOLD if getattr(c, "bold", False) else 0) \
                         | (_c.A_REVERSE if getattr(c, "reverse", False) else 0) \
                         | (_c.A_UNDERLINE if getattr(c, "underscore", False) else 0)
                if c_fg != fg or c_attr != (run_attr & (_c.A_BOLD | _c.A_REVERSE | _c.A_UNDERLINE)):
                    break
                run_chars.append(c.data if c.data else " ")
                x += 1
            if run_chars:
                try:
                    stdscr.addstr(oy + y, ox + x - len(run_chars),
                                  "".join(run_chars), run_attr)
                except _c.error:
                    pass
        # Clear remaining cells on this line (if any) to avoid stale chars.
        # (Already covered by win.erase() before render, so this is a no-op
        # safety net.)
    # Move the cursor to pyte's cursor position (clamped to the region).
    cx = min(getattr(screen.cursor, "x", 0), dw - 1)
    cy = min(getattr(screen.cursor, "y", 0), dh - 1)
    try:
        stdscr.move(oy + cy, ox + cx)
    except _c.error:
        pass


def _build_capture_rcfile(cmd_path: str, cwd_path: str, env_path: str) -> str:
    """Build the bash rcfile that lets F5 capture the current command line.

    Sources ~/.bashrc (so conda/aliases work), defines __gq_capture (writes
    $READLINE_LINE, $PWD, env -0 to the three temp files without executing
    the command), and binds F5 (\\e[15~) to call it. Returns the rcfile
    content string. Pure (no I/O).
    """
    return (
        "[ -f ~/.bashrc ] && source ~/.bashrc || true\n"
        "__gq_capture() {\n"
        f"  printf '%s' \"$READLINE_LINE\" > {cmd_path}\n"
        f"  pwd > {cwd_path}\n"
        f"  env -0 > {env_path}\n"
        "  exit 0\n"
        "}\n"
        'bind -x \'"\\e[15~": "__gq_capture"\'\n'
        'echo "[gq] compose your command, then press F5 to submit (Esc to cancel)."\n'
    )


def _run_embedded_bash(stdscr, oy, ox):
    """Spawn a real bash in a pty, rendered inside a curses dialog at (oy, ox).

    F5 submits the current command line (via the rcfile __gq_capture bind);
    Esc cancels; Ctrl-C is forwarded to bash (gq itself ignores SIGINT during
    the modal loop). Returns {"cmd","cwd","env"} on F5, or None on Esc / bash
    exit. Lazy-imports pyte; if pyte is missing, prints an install hint and
    returns None. Cleans up the pty, process, and 4 temp files on every path.
    """
    import curses as _c
    try:
        import pyte
    except ImportError:
        print("\n[gq] TUI add needs pyte: pip install pyte", file=sys.stderr)
        return None

    h, w = stdscr.getmaxyx()
    dh = max(8, int(h * 0.6))
    dw = max(40, w - ox - 2)  # as wide as possible from ox to right edge
    # Clamp so the dialog fits below/right of the origin and on-screen.
    dh = min(dh, h - oy - 1)
    dw = min(dw, w - ox - 1)
    if dh < 3 or dw < 3:
        # Not enough room to draw a bordered dialog — bail cleanly.
        return None

    import tempfile, pty, select, fcntl, termios, struct, signal
    cmd_fd, cmd_path = tempfile.mkstemp(prefix="gq_cmd_")
    cwd_fd, cwd_path = tempfile.mkstemp(prefix="gq_cwd_")
    env_fd, env_path = tempfile.mkstemp(prefix="gq_env_")
    rc_fd, rc_path = tempfile.mkstemp(prefix="gq_rc_")
    for fd in (cmd_fd, cwd_fd, env_fd, rc_fd):
        os.close(fd)
    # Write the rcfile simply (the skeleton's os.write guard was a no-op bug).
    with open(rc_path, "w") as f:
        f.write(_build_capture_rcfile(cmd_path, cwd_path, env_path))

    screen = pyte.Screen(dw, dh)
    stream = pyte.Stream(screen)

    master, slave = pty.openpty()
    # Set the pty window size so bash/readline know the dialog dimensions.
    winsize = struct.pack("HHHH", dh, dw, 0, 0)
    try:
        fcntl.ioctl(slave, termios.TIOCSWINSZ, winsize)
    except OSError:
        pass

    import subprocess
    try:
        proc = subprocess.Popen(["bash", "--rcfile", rc_path, "-i"],
                                stdin=slave, stdout=slave, stderr=slave,
                                preexec_fn=os.setsid, env={**os.environ})
    except Exception as exc:
        # bash failed to spawn — clean up master + slave + temp files and bail.
        # Popen is outside the main try/finally below, so it gets its own
        # cleanup to avoid leaking fds/temp files.
        print(f"[gq] ERROR spawning bash: {exc}", file=sys.stderr)
        try:
            os.close(master)
        except OSError:
            pass
        try:
            os.close(slave)
        except OSError:
            pass
        for p in (cmd_path, cwd_path, env_path, rc_path):
            try:
                os.unlink(p)
            except OSError:
                pass
        return None
    os.close(slave)  # parent only needs master; bash keeps the slave open

    # Override SIGINT so Ctrl-C is NOT delivered to gq; we forward \x03 to bash.
    # SIGINT-ignore + blocking-mode setup lives INSIDE try so a raise from
    # _tui_blocking_mode (curses.error on nocbreak/cbreak) is caught by finally:
    # SIGINT restored, master closed, bash killed, temp files unlinked.
    old_sigint = signal.SIG_DFL  # safe default in case signal.signal itself raises
    result = None
    try:
        old_sigint = signal.signal(signal.SIGINT, signal.SIG_IGN)
        _tui_blocking_mode(stdscr)  # blocking getch for the modal loop
        # cbreak (set by curses.wrapper / _tui_blocking_mode) keeps ISIG, so the
        # tty driver intercepts Ctrl-C (SIGINT, which gq ignores) and never
        # delivers \x03 to getch. raw() clears ISIG so \x03 reaches getch →
        # _key_to_bytes(3) forwards it to bash's foreground job. Also show the
        # cursor so the user can see their input position in the dialog (the
        # main TUI loop hides it via curs_set(0)). Guard each call: some
        # terminals reject raw/curs_set, and the mocked tests run without
        # initscr() so these module-level calls raise curses.error there.
        try:
            _c.raw()
        except _c.error:
            pass
        try:
            _c.curs_set(1)
        except _c.error:
            pass
        # Create the dialog subwindow ONCE and reuse it every cycle (creating a
        # new subwin per iteration is wasteful and contributes to input lag).
        try:
            win = stdscr.subwin(dh, dw, oy, ox)
        except _c.error:
            win = stdscr
        # Only redraw when something changed (bash output arrived or a key was
        # pressed). Redrawing every cycle even when nothing changed is the main
        # source of input lag — the per-cell _render_pyte_to_dialog traversal
        # (784+ cells for a 14×56 dialog) runs every 0.2s even if the screen
        # is idle, blocking getch and making typing feel laggy.
        dirty = True  # draw once on entry
        while True:
            # 1. Read bash output, feed pyte. Use a small select timeout (5ms)
            # instead of 0 so bash has time to echo the key we just forwarded —
            # without this, the echo arrives on the NEXT halfdelay cycle (0.2s
            # later), making typing feel laggy (the char doesn't appear until
            # 160-200ms after the keypress).
            got_output = False
            while True:
                r, _, _ = select.select([master], [], [], 0.005)
                if not r:
                    break
                try:
                    data = os.read(master, 4096)
                except OSError:
                    data = b""
                if not data:
                    break
                stream.feed(data.decode("utf-8", "replace"))
                got_output = True
            # 2. Render the dialog ONLY if dirty (new output or key pressed).
            if got_output or dirty:
                try:
                    win.erase()
                    win.box()
                    win.addstr(0, 2, " compose (F5 submit, Esc cancel) ",
                               _c.A_BOLD)
                    _render_pyte_to_dialog(win, screen, 1, 1, dh - 2, dw - 2)
                    win.noutrefresh()
                except _c.error:
                    pass
                # Bottom hint on stdscr (outside the dialog subwindow).
                try:
                    stdscr.addstr(h - 1, 0,
                                  " F5 submit  Esc cancel  Ctrl-C interrupt  |  Tab: complete  Ctrl-R: search history  ↑↓: history "[:w - 1],
                                  _c.color_pair(4))
                except _c.error:
                    pass
                stdscr.noutrefresh()
                # Move the cursor to pyte's cursor position AFTER all
                # noutrefresh, BEFORE doupdate (see comment above).
                try:
                    cx = min(getattr(screen.cursor, "x", 0), dw - 2)
                    cy = min(getattr(screen.cursor, "y", 0), dh - 2)
                    stdscr.move(oy + 1 + cy, ox + 1 + cx)
                except _c.error:
                    pass
                _c.doupdate()
                dirty = False
            # 3. Get a key. keypad(False) makes 0x1b (Esc) return immediately
            # as 27 (no 1s curses disambiguation wait). BUT arrow keys also
            # start with 0x1b — so on seeing 27 we do a quick nodelay peek:
            # if there's a follow-up byte ([, O, etc.) it's an escape sequence
            # (arrow key, Home, etc.) → forward the whole thing to bash; if
            # there's nothing following, it's a real Esc → cancel.
            stdscr.keypad(False)
            _c.halfdelay(1)  # 0.1s timeout — reads bash output promptly
            ch = stdscr.getch()
            if ch == 27:
                # Possible Esc OR start of an escape sequence (arrow keys etc).
                # Peek at the next byte with a tiny timeout to disambiguate.
                stdscr.nodelay(True)
                time.sleep(0.01)  # 10ms — enough for the rest of the seq
                ch2 = stdscr.getch()
                if ch2 != -1:
                    # It's an escape sequence, not Esc. Forward \x1b + ch2
                    # (+ any more bytes) to bash so readline handles arrows.
                    seq = b"\x1b" + bytes([ch2])
                    # Read any remaining bytes of the sequence (e.g. [A = 3 bytes)
                    while True:
                        ch3 = stdscr.getch()
                        if ch3 == -1:
                            break
                        seq += bytes([ch3])
                    try:
                        os.write(master, seq)
                    except OSError:
                        pass
                    ch = -1  # not a real key for gq; just redraw
                # else: real Esc, ch stays 27 → falls through to the Esc break
                stdscr.nodelay(False)
            stdscr.keypad(True)  # restore for main panel
            if ch != -1:
                dirty = True  # a key was pressed → redraw next cycle
            if ch == _c.KEY_F5:
                # Forward F5 (\e[15~) to bash so the rcfile's `bind -x`
                # fires __gq_capture, which writes the temp files (cmd, then
                # cwd, then env) and exits bash. F5 is reserved in
                # _key_to_bytes (not auto-forwarded), so we forward it
                # explicitly here. __gq_capture runs asynchronously in bash,
                # so we wait for it to finish before reading: proc.poll()
                # becoming non-None (bash exited via `exit 0`) is the
                # deterministic completion signal. As a fallback (e.g. tests
                # where poll is mocked to None), env_path being non-empty also
                # indicates completion — env is written LAST, so cmd & cwd are
                # already written by then. 2s timeout; if the bind never fires,
                # cmd stays empty and we return None (graceful cancel).
                try:
                    os.write(master, b"\x1b[15~")
                except OSError:
                    pass
                deadline = time.monotonic() + 2.0
                while time.monotonic() < deadline:
                    if proc.poll() is not None:
                        break  # bash exited → __gq_capture done → all files written
                    try:
                        if Path(env_path).read_bytes():
                            break  # env written last → cmd, cwd already complete
                    except OSError:
                        pass
                    time.sleep(0.02)
                try:
                    cmd = Path(cmd_path).read_text()
                except OSError:
                    cmd = ""
                if cmd:
                    cwd = Path(cwd_path).read_text().strip()
                    env = {}
                    raw = Path(env_path).read_bytes()
                    for entry in raw.split(b"\x00"):
                        if b"=" in entry:
                            k, _, v = entry.partition(b"=")
                            try:
                                env[k.decode()] = v.decode()
                            except UnicodeDecodeError:
                                continue
                    result = {"cmd": cmd, "cwd": cwd, "env": env}
                break
            if ch == 27:  # Esc
                break
            kb = _key_to_bytes(ch)
            if kb is not None:
                try:
                    os.write(master, kb)
                except OSError:
                    break
            # If bash exited (Ctrl-D in bash), drain remaining output then break.
            if proc.poll() is not None:
                try:
                    data = os.read(master, 4096)
                    if data:
                        stream.feed(data.decode("utf-8", "replace"))
                except OSError:
                    pass
                break
    finally:
        # Leave raw mode and return to cbreak (what the main TUI loop expects),
        # then hide the cursor again (the main TUI loop uses curs_set(0)).
        try:
            _c.noraw()
            _c.cbreak()
        except _c.error:
            pass
        try:
            _c.curs_set(0)
        except _c.error:
            pass
        _tui_restore_halfdelay(stdscr)
        signal.signal(signal.SIGINT, old_sigint)
        # Kill bash FIRST (before closing master) so it dies cleanly, then wait
        # with a 1s timeout so a hung bash doesn't block the TUI on Esc.
        try:
            child_pgid = os.getpgid(proc.pid)
        except (ProcessLookupError, OSError):
            child_pgid = None
        my_pgid = os.getpgid(0)  # gq's own process group
        killed_group = False
        if (child_pgid is not None
                and child_pgid != my_pgid
                and child_pgid > 0
                and child_pgid != proc.pid + 1):
            if child_pgid == proc.pid:
                try:
                    os.killpg(child_pgid, signal.SIGKILL)
                    killed_group = True
                except (ProcessLookupError, OSError):
                    pass
        if not killed_group:
            try:
                proc.kill()
            except Exception:
                pass
        try:
            proc.wait(timeout=1.0)
        except Exception:
            pass
        try:
            os.close(master)
        except OSError:
            pass
        for p in (cmd_path, cwd_path, env_path, rc_path):
            try:
                os.unlink(p)
            except OSError:
                pass
    return result


def main():
    parser = argparse.ArgumentParser(
        prog="gq", description="GPU Task Queue — run jobs when GPU is free"
    )
    sub = parser.add_subparsers(dest="cmd")
    sub.required = False

    p_watch = sub.add_parser("watch", help="Start the daemon (run in tmux)")
    p_watch.add_argument("--poll", type=int, default=15,
                         help="Poll interval in seconds (default: 15)")

    p_add = sub.add_parser("add", help="Add a command to the queue")
    p_add.add_argument("command", help="Shell command to run")
    p_add.add_argument("--gpus", type=int, default=None,
                       help="Number of GPUs the job needs (default: 1, single-card)")

    sub.add_parser("list", help="Show queue and current status")

    p_cancel = sub.add_parser("cancel", help="Remove a pending job by ID or prefix")
    p_cancel.add_argument("job_id", help="Job ID or unique prefix")

    sub.add_parser("clear", help="Clear all pending jobs")

    p_stop = sub.add_parser("stop", help="Stop a running job by ID")
    p_stop.add_argument("job_id", help="Job ID or unique prefix")

    args = parser.parse_args()
    QUEUE_DIR.mkdir(parents=True, exist_ok=True)

    if args.cmd is None:
        # No subcommand → enter the TUI.
        try:
            curses.wrapper(_tui_main)
        except Exception as exc:
            # curses.wrapper restores the terminal even on exception.
            print(f"[gq] TUI error: {exc}", file=sys.stderr)
            sys.exit(1)
        return

    dispatch = {
        "watch": cmd_watch,
        "add": cmd_add,
        "list": cmd_list,
        "cancel": cmd_cancel,
        "clear": cmd_clear,
        "stop": cmd_stop,
    }
    dispatch[args.cmd](args)


if __name__ == "__main__":
    main()
