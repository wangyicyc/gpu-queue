#!/usr/bin/env python3
"""gq — GPU Task Queue: run shell commands when your GPU is free."""

import argparse
import datetime
import fcntl
import json
import os
import secrets
import signal
import subprocess
import sys
import time
from contextlib import contextmanager
from pathlib import Path
from typing import Optional

QUEUE_DIR = Path.home() / ".gpu-queue"
QUEUE_FILE = QUEUE_DIR / "queue.json"
STATE_FILE = QUEUE_DIR / "state.json"
LOG_DIR = QUEUE_DIR / "logs"


_TOTAL_CARDS = None  # type: Optional[int]


def _total_cards() -> int:
    """Count GPUs via nvidia-smi -L. Cached after first call."""
    global _TOTAL_CARDS
    if _TOTAL_CARDS is not None:
        return _TOTAL_CARDS
    try:
        result = subprocess.run(
            ["nvidia-smi", "-L"],
            capture_output=True, text=True, timeout=10
        )
        # Each GPU is one line: "GPU 0: NVIDIA GeForce ..."
        _TOTAL_CARDS = sum(1 for line in result.stdout.splitlines()
                           if line.startswith("GPU "))
        if _TOTAL_CARDS == 0:
            _TOTAL_CARDS = 1  # fallback so idle math doesn't divide weirdly
    except (FileNotFoundError, subprocess.TimeoutExpired):
        _TOTAL_CARDS = 1
    return _TOTAL_CARDS


def busy_cards() -> set:
    """Return the set of physical GPU indices with a compute (type=C) process
    owned by the current user. Graphics (type=G) and other users' processes
    do not count. On nvidia-smi failure/timeout, returns ALL card indices
    (safe default: daemon treats all as busy -> no launch).
    """
    uid = os.getuid()
    total = _total_cards()
    try:
        result = subprocess.run(
            ["nvidia-smi", "pmon", "-s", "um", "-c", "1"],
            capture_output=True, text=True, timeout=10
        )
    except FileNotFoundError:
        print("[gq] ERROR: nvidia-smi not found. Is the NVIDIA driver installed?",
              file=sys.stderr)
        sys.exit(1)
    except subprocess.TimeoutExpired:
        print("[gq] WARNING: nvidia-smi timed out, treating all GPUs as busy.",
              file=sys.stderr)
        return set(range(total))

    if result.returncode != 0:
        print(f"[gq] WARNING: nvidia-smi failed (exit {result.returncode}), "
              "treating all GPUs as busy.", file=sys.stderr)
        return set(range(total))

    busy = set()
    for line in result.stdout.splitlines():
        if line.startswith("#") or not line.strip():
            continue
        parts = line.split()
        if len(parts) < 3:
            continue
        if parts[2] != "C":          # skip Graphics (G)
            continue
        try:
            gpu = int(parts[0])
            pid = int(parts[1])
            if os.stat(f"/proc/{pid}").st_uid == uid:
                busy.add(gpu)
        except (ValueError, FileNotFoundError, PermissionError):
            continue
    return busy


def _pick_idle(idle: set, n: int) -> list:
    """Pick n idle card indices (lowest indices first)."""
    return sorted(idle)[:n]


def _lock_and_read(path: Path, default):
    """Read JSON from path with exclusive lock. Returns default on missing/corrupt."""
    path.touch(exist_ok=True)
    with open(path, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            content = f.read().strip()
            return json.loads(content) if content else default
        except (UnicodeDecodeError, ValueError):
            print(f"[gq] WARNING: {path.name} corrupted, resetting.", file=sys.stderr)
            return default
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


def _lock_and_write(path: Path, data) -> None:
    """Write JSON to path with exclusive lock."""
    path.touch(exist_ok=True)
    with open(path, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            f.seek(0)
            f.write(json.dumps(data, indent=2))
            f.truncate()
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


@contextmanager
def _locked_queue():
    """Hold the lock across a read-modify-write on queue.json.

    Yields the queue list; mutations made in-place are persisted on exit.
    The fcntl lock is held for the whole RMW, so concurrent writers cannot
    lose jobs by interleaving read/write.
    """
    QUEUE_FILE.touch(exist_ok=True)
    with open(QUEUE_FILE, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            content = f.read().strip()
            try:
                q = json.loads(content) if content else []
            except (UnicodeDecodeError, ValueError):
                print("[gq] WARNING: queue.json corrupted, resetting.",
                      file=sys.stderr)
                q = []
            if not isinstance(q, list):
                print("[gq] WARNING: queue.json corrupted (non-list), resetting.",
                      file=sys.stderr)
                q = []
            yield q
            f.seek(0)
            f.write(json.dumps(q, indent=2))
            f.truncate()
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


def read_queue() -> list:
    q = _lock_and_read(QUEUE_FILE, [])
    if not isinstance(q, list):
        print("[gq] WARNING: queue.json corrupted (non-list), resetting.",
              file=sys.stderr)
        return []
    return q


def write_queue(jobs: list) -> None:
    _lock_and_write(QUEUE_FILE, jobs)


def read_state() -> dict:
    default = {"daemon_pid": None, "running": {}}
    state = _lock_and_read(STATE_FILE, default)
    if not isinstance(state, dict):
        print("[gq] WARNING: state.json corrupted (non-object), resetting.", file=sys.stderr)
        return dict(default)
    running = state.get("running")
    # New shape: running is a dict keyed by job id (possibly empty).
    # Old shape: running was None or a single job dict with "id"/"pid". Migrate
    # those to {} so the dict-keyed model never sees a stale single-job entry.
    # Heuristic: a single-job dict has "id" and "pid" keys whose values are NOT
    # dicts; a dict-of-jobs has dict values (or is empty).
    if running is None or (isinstance(running, dict) and "id" in running and "pid" in running
                           and not any(isinstance(v, dict) for v in running.values())):
        state["running"] = {}
    elif not isinstance(running, dict):
        state["running"] = {}
    # Ensure required keys exist even if file had partial data
    return {**default, **state}


def write_state(state: dict) -> None:
    _lock_and_write(STATE_FILE, state)


def _make_job(cmd: str, cwd: str, n: int = 1) -> dict:
    return {
        "id": secrets.token_hex(2),
        "cmd": cmd,
        "cwd": cwd,
        "added_at": datetime.datetime.now().isoformat(timespec="seconds"),
        # Snapshot the caller's environment so the daemon can re-create it at
        # execution time. Popen(env=...) is a full replacement, not a merge, so
        # the entire dict must be stored (conda/venv activation rewrites PATH and
        # sets many CONDA_* / VIRTUAL_ENV vars that a cherry-pick would drop).
        "env": dict(os.environ),
        "n": n,
    }


def cmd_add(args) -> None:
    n = args.gpus if args.gpus is not None else 1
    job = _make_job(args.command, os.getcwd(), n=n)
    with _locked_queue() as q:
        q.append(job)
    if args.gpus is None:
        print(f"[gq] no --gpus given, running as single-card job")
    print(f"[gq] added job {job['id']}: {args.command}")


def _env_name(job: dict) -> str:
    """Return a short human-readable name for the job's captured environment.

    Prefers CONDA_DEFAULT_ENV (set by conda activate), else the basename of
    VIRTUAL_ENV (set by venv/activate). Returns "" if neither is present.
    Reads from the job's captured env snapshot, NOT os.environ — the daemon
    runs in a different environment than the shell that added the job.
    """
    env = job.get("env") or {}
    if env.get("CONDA_DEFAULT_ENV"):
        return env["CONDA_DEFAULT_ENV"]
    venv = env.get("VIRTUAL_ENV")
    if venv:
        return os.path.basename(venv)
    return ""


def cmd_list(args) -> None:
    state = read_state()
    queue = read_queue()

    # Running jobs (now potentially multiple)
    running = state.get("running") or {}
    if running:
        print("[gq] running:")
        for rid, r in running.items():
            try:
                started = datetime.datetime.fromisoformat(r["started_at"])
                elapsed = str(datetime.datetime.now() - started).split(".")[0]
            except (KeyError, ValueError, TypeError):
                elapsed = "unknown"
            cards = ",".join(str(c) for c in r.get("cards", []))
            ename = _env_name(r)
            suffix = f"  [{ename}]" if ename else ""
            gpu = f"  GPU {cards}" if cards else ""
            print(f"  {rid}  {r['cmd']}{gpu}   started {elapsed} ago{suffix}")
    else:
        print("[gq] running: none")

    # Pending queue
    n = len(queue)
    label = f"{n} job" + ("s" if n != 1 else "")
    print(f"\n[gq] queue ({label}):")
    if not queue:
        print("  (empty)")
    for i, job in enumerate(queue, 1):
        ename = _env_name(job)
        suffix = f"  [{ename}]" if ename else ""
        print(f"  #{i}  {job['id']}  {job['cmd']}{suffix}")

    # Daemon status
    dpid = state.get("daemon_pid")
    if dpid:
        try:
            os.kill(dpid, 0)
            print(f"\n[gq] daemon: running (pid {dpid})")
        except (ProcessLookupError, TypeError):
            print(f"\n[gq] daemon: stale pid {dpid} (not running)")
    else:
        print("\n[gq] daemon: not running — start with: gq watch")


def cmd_cancel(args) -> None:
    job_id = args.job_id

    # Check if it's a running job (read_state uses its own lock — do NOT
    # hold the queue lock while checking state). running is a dict keyed by
    # job id; refuse to cancel any job that is currently running.
    state = read_state()
    running = state.get("running") or {}
    match = next((rid for rid in running if rid.startswith(job_id)), None)
    if match:
        print(f"[gq] job {match} is currently running. "
              "Use 'gq stop' to stop it (the daemon stays alive).")
        return

    with _locked_queue() as q:
        matches = [j for j in q if j["id"].startswith(job_id)]

        if not matches:
            print(f"[gq] job '{job_id}' not found in queue.")
            return
        if len(matches) > 1:
            ids = ", ".join(j["id"] for j in matches)
            print(f"[gq] ambiguous prefix '{job_id}' matches: {ids}. Be more specific.")
            return

        target = matches[0]
        # Mutate the yielded list in place so the RMW persists.
        q[:] = [j for j in q if j["id"] != target["id"]]
    print(f"[gq] cancelled job {target['id']}: {target['cmd']}")


def cmd_clear(args) -> None:
    with _locked_queue() as q:
        n = len(q)
        q[:] = []
    print(f"[gq] cleared {n} pending job{'s' if n != 1 else ''}.")


def cmd_stop(args) -> None:
    """Stop a specific running job by ID (SIGKILL its process group).

    With multiple jobs running concurrently, an ID is required. The daemon
    stays alive and reaps the killed job, releasing its cards.
    """
    state = read_state()
    running = state.get("running") or {}
    job_id = args.job_id

    matches = [jid for jid in running if jid.startswith(job_id)]
    if not matches:
        print(f"[gq] no running job matches '{job_id}'.")
        return
    if len(matches) > 1:
        ids = ", ".join(matches)
        print(f"[gq] ambiguous prefix '{job_id}' matches: {ids}. Be more specific.")
        return

    target_id = matches[0]
    rpid = running[target_id].get("pid")
    if not rpid:
        print(f"[gq] job {target_id} has no pid yet (not fully started).")
        return
    try:
        pgid = os.getpgid(rpid)
        os.killpg(pgid, signal.SIGKILL)
    except ProcessLookupError:
        print(f"[gq] job {target_id} already finished (pid {rpid} not found).")
        return
    except PermissionError as exc:
        print(f"[gq] ERROR: cannot stop job {target_id} (pid {rpid}): {exc}")
        return
    print(f"[gq] stopped job {target_id} (pid {rpid}).")


def _format_elapsed(seconds: float) -> str:
    """Format seconds as HH:MM:SS."""
    s = int(seconds)
    return f"{s // 3600:02d}:{(s % 3600) // 60:02d}:{s % 60:02d}"


def _build_rows(state: dict, queue: list) -> list:
    """Build the TUI operations list from current state + queue. Pure (no curses).

    Row order: Add, then one Stop + one Open-log per running job, then one
    Cancel per queued job, then Clear, Quit. Each row:
      {"kind": "op"|"job", "label": str, "action": str, "job_id": str|None}
    """
    rows = []
    rows.append({"kind": "op", "label": "Add job",
                 "action": "add", "job_id": None})
    running = state.get("running") or {}
    for rid, r in running.items():
        cards = ",".join(str(c) for c in r.get("cards", []))
        rows.append({"kind": "job", "label": f"Stop: {rid}  ({r.get('cmd','')} GPU {cards})",
                     "action": "stop", "job_id": rid})
    for rid, r in running.items():
        rows.append({"kind": "job", "label": f"Open log: {rid}",
                     "action": "open_log", "job_id": rid})
    for i, job in enumerate(queue, 1):
        rows.append({"kind": "job",
                     "label": f"Cancel: #{i} {job['id']}  ({job.get('cmd','')})",
                     "action": "cancel", "job_id": job["id"]})
    rows.append({"kind": "op", "label": "Clear queue",
                 "action": "clear", "job_id": None})
    rows.append({"kind": "op", "label": "Quit",
                 "action": "quit", "job_id": None})
    return rows


def _launch_job(job: dict, cards: list) -> Optional[subprocess.Popen]:
    """Launch a job on the given cards (non-blocking). Returns the Popen, or
    None on launch failure. Injects CUDA_VISIBLE_DEVICES into the job's env.
    Task stdout/stderr is redirected to ~/.gpu-queue/logs/<id>.log (the watch
    terminal prints only summary lines; the TUI can display the log tail).
    """
    cwd = job["cwd"]
    if not os.path.isdir(cwd):
        print(f"[gq] WARNING: cwd '{cwd}' does not exist, skipping job {job['id']}.")
        return None
    env = dict(job.get("env") or {})
    env["CUDA_VISIBLE_DEVICES"] = ",".join(str(c) for c in cards)
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    log_path = LOG_DIR / f"{job['id']}.log"
    try:
        log_f = open(log_path, "w")
    except OSError as exc:
        print(f"[gq] ERROR opening log {log_path}: {exc}")
        return None
    print(f"[gq] >>> {job['cmd']}   (GPU {','.join(str(c) for c in cards)})   log: {log_path}")
    try:
        proc = subprocess.Popen(job["cmd"], shell=True, cwd=cwd,
                                start_new_session=True, env=env,
                                stdout=log_f, stderr=log_f)
    except Exception as exc:
        log_f.close()
        print(f"[gq] ERROR running job {job['id']}: {exc}")
        return None
    # Popen sets self.stdout = None when stdout is a file (not PIPE), so retain
    # the handle ourselves for the daemon to flush/close when the job is reaped
    # (see _daemon_loop reap block). NOTE: log_f is intentionally not closed
    # here — the child writes to its fd asynchronously.
    proc.stdout = log_f
    return proc


# Module-level state for the concurrent loop. _shutdown_requested lets the
# SIGINT handler ask the loop to stop; _running holds live jobs so the handler
# can force-kill ALL of them on a second Ctrl-C. _running is module-level so it
# persists across loop iterations (the loop does NOT reset it on entry).
_shutdown_requested = False
_running = {}  # type: dict  # {id: {"proc": Popen, "job": dict, "cards": [int], "start": float}}


def _force_kill_all_running() -> None:
    """SIGKILL every running job's process group (the second-Ctrl-C path).

    shell=True spawns /bin/sh -c <cmd>, so killing only the shell pid would
    orphan the real command; SIGKILL each group via os.killpg. Extracted to a
    module-level helper so it is unit-testable without delivering real signals.
    """
    for rid, info in list(_running.items()):
        pid = info["proc"].pid
        try:
            os.killpg(os.getpgid(pid), signal.SIGKILL)
        except ProcessLookupError:
            pass


def _daemon_loop(poll_interval: int) -> None:
    """Concurrent multi-GPU polling loop. Launches the queue head when enough
    idle cards exist; reaps finished jobs each cycle. Exits on shutdown."""
    global _shutdown_requested
    _shutdown_requested = False

    ctrl_c_count = [0]

    def _handle_sigint(sig, frame):
        ctrl_c_count[0] += 1
        if ctrl_c_count[0] == 1:
            print("\n[gq] Ctrl-C received. Waiting for running jobs to finish. "
                  "Press Ctrl-C again to force-kill all.", file=sys.stderr)
            _shutdown_requested = True
        else:
            # Second Ctrl-C: SIGKILL ALL running jobs' process groups.
            _force_kill_all_running()
            sys.exit(0)

    old_handler = signal.signal(signal.SIGINT, _handle_sigint)
    try:
        # Keep looping while not shutting down OR there are still live jobs to
        # reap. After the first Ctrl-C sets _shutdown_requested, the loop drains
        # _running (reaping finished jobs) but does NOT launch new ones — the
        # launch block below is gated on `not _shutdown_requested`. Only when
        # every live job has been reaped does the loop exit, so graceful Ctrl-C
        # no longer orphans jobs that are still running on the GPU.
        while not _shutdown_requested or _running:
            # 1. Reap finished jobs (always, even after shutdown requested).
            for rid in list(_running.keys()):
                info = _running[rid]
                code = info["proc"].poll()
                if code is not None:
                    elapsed = _format_elapsed(time.monotonic() - info["start"])
                    if code == 0:
                        print(f"[gq] <<< job {rid} DONE (exit=0) in {elapsed}")
                    else:
                        print(f"[gq] <<< job {rid} FAILED (exit={code}) in {elapsed}")
                    # Flush/close the per-job log file (retained on proc.stdout by
                    # _launch_job). Guarded: legacy/fake procs may lack stdout.
                    _logf = getattr(info["proc"], "stdout", None)
                    if _logf is not None:
                        _logf.close()
                    del _running[rid]
                    _state = read_state()
                    _state.setdefault("running", {}).pop(rid, None)
                    write_state(_state)

            # 2. Launch as many queued jobs as fit the idle cards this cycle
            # (NOT just the head) so concurrent multi-GPU jobs start together
            # instead of being staggered by poll_interval seconds each. After
            # graceful shutdown is requested, skip launching so no new jobs
            # start while we drain the live ones.
            if not _shutdown_requested:
                total = _total_cards()
                busy = busy_cards()
                # Cards already assigned to running jobs are not idle even if
                # nvidia-smi hasn't caught up.
                assigned = set()
                for info in _running.values():
                    assigned.update(info["cards"])
                idle = set(range(total)) - busy - assigned

                # Launch in a loop: re-derive idle (subtracting each just-launched
                # job's cards) so the next job gets DIFFERENT cards. Strict FIFO:
                # if the head doesn't fit, break — don't skip to smaller jobs.
                while True:
                    with _locked_queue() as q:
                        if not q:
                            break
                        head = q[0]
                        n = head.get("n", 1)
                        if len(idle) < n:
                            break  # head doesn't fit; don't skip (strict FIFO)
                        q.pop(0)
                    cards = _pick_idle(idle, n)
                    proc = _launch_job(head, cards)
                    if proc is not None:
                        head["started_at"] = datetime.datetime.now().isoformat(timespec="seconds")
                        _running[head["id"]] = {"proc": proc, "job": head,
                                                "cards": cards, "start": time.monotonic()}
                        _state = read_state()
                        _state.setdefault("running", {})[head["id"]] = {
                            **head, "cards": cards, "pid": proc.pid
                        }
                        write_state(_state)
                        print(f"\n[gq] GPU idle — starting job {head['id']} on "
                              f"GPU {','.join(str(c) for c in cards)}")
                        # Reserve these cards so the next iteration picks
                        # different ones.
                        idle = idle - set(cards)
                    else:
                        # launch failed (bad cwd) — job already popped; don't
                        # loop forever trying to re-launch it.
                        break

            time.sleep(poll_interval)
    finally:
        signal.signal(signal.SIGINT, old_handler)

    print("[gq] daemon exiting.")


def cmd_watch(args) -> None:
    # Check for existing daemon
    state = read_state()
    dpid = state.get("daemon_pid")
    if dpid:
        try:
            os.kill(dpid, 0)
            print(f"[gq] daemon already running (pid {dpid}). Exiting.")
            return
        except ProcessLookupError:
            pass  # stale pid — proceed

    # Clear stale running entries on startup (crash recovery). running is now a
    # dict keyed by job id; for each entry, if the recorded pid is still alive
    # the previous daemon was killed mid-job and the orphan is still on the GPU
    # — kill its process group. Stale (dead) entries are just cleared.
    running = state.get("running") or {}
    if running:
        for rid, r in list(running.items()):
            rpid = r.get("pid")
            alive = False
            if rpid:
                try:
                    # Job runs in its own session/group (start_new_session=True),
                    # so getpgid(rpid) == rpid. Check liveness via the group.
                    os.killpg(os.getpgid(rpid), 0)
                    alive = True
                except ProcessLookupError:
                    pass
                except (TypeError, PermissionError):
                    pass  # pid None/non-int or not ours — treat as stale
            if alive:
                print(f"[gq] WARNING: orphaned job {rid} (pid {rpid}) still running "
                      "from a previous daemon crash; killing its process group.",
                      file=sys.stderr)
                try:
                    os.killpg(os.getpgid(rpid), signal.SIGKILL)
                except ProcessLookupError:
                    pass
            else:
                print(f"[gq] WARNING: stale running entry for job {rid} "
                      "cleared (process no longer running).", file=sys.stderr)
        state["running"] = {}

    # Register this daemon
    state["daemon_pid"] = os.getpid()
    write_state(state)

    print(f"[gq] daemon started (pid {os.getpid()}), polling every {args.poll}s")
    print("[gq] Ctrl-C to stop gracefully. Press twice to force-kill.\n")

    try:
        _daemon_loop(args.poll)
    finally:
        # Clear only the daemon_pid. Do NOT blanket-clear state["running"]:
        # on a graceful exit the loop has already drained _running to empty
        # (each reaped job is popped from state["running"] as it finishes), so
        # state["running"] is already {}. On a force-kill (2nd Ctrl-C),
        # _force_kill_all_running SIGKILLed the process groups but they may
        # not have been reaped yet — leaving state["running"] lets the next
        # `gq watch` reap them via crash-recovery (live orphans are killed,
        # dead entries are cleared as stale). Clearing here would orphan jobs
        # that are still alive on the GPU.
        s = read_state()
        s["daemon_pid"] = None
        write_state(s)


def main():
    parser = argparse.ArgumentParser(
        prog="gq", description="GPU Task Queue — run jobs when GPU is free"
    )
    sub = parser.add_subparsers(dest="cmd")
    sub.required = True

    p_watch = sub.add_parser("watch", help="Start the daemon (run in tmux)")
    p_watch.add_argument("--poll", type=int, default=15,
                         help="Poll interval in seconds (default: 15)")

    p_add = sub.add_parser("add", help="Add a command to the queue")
    p_add.add_argument("command", help="Shell command to run")
    p_add.add_argument("--gpus", type=int, default=None,
                       help="Number of GPUs the job needs (default: 1, single-card)")

    sub.add_parser("list", help="Show queue and current status")

    p_cancel = sub.add_parser("cancel", help="Remove a pending job by ID or prefix")
    p_cancel.add_argument("job_id", help="Job ID or unique prefix")

    sub.add_parser("clear", help="Clear all pending jobs")

    p_stop = sub.add_parser("stop", help="Stop a running job by ID")
    p_stop.add_argument("job_id", help="Job ID or unique prefix")

    args = parser.parse_args()
    QUEUE_DIR.mkdir(parents=True, exist_ok=True)

    dispatch = {
        "watch": cmd_watch,
        "add": cmd_add,
        "list": cmd_list,
        "cancel": cmd_cancel,
        "clear": cmd_clear,
        "stop": cmd_stop,
    }
