#!/usr/bin/env python3
"""gq — GPU Task Queue: run shell commands when your GPU is free."""

import argparse
import datetime
import fcntl
import json
import os
import secrets
import signal
import subprocess
import sys
import time
from contextlib import contextmanager
from pathlib import Path
from typing import Optional

QUEUE_DIR = Path.home() / ".gpu-queue"
QUEUE_FILE = QUEUE_DIR / "queue.json"
STATE_FILE = QUEUE_DIR / "state.json"


def gpu_is_idle() -> bool:
    """Return True if no process owned by the current user is using the GPU."""
    uid = os.getuid()
    try:
        result = subprocess.run(
            ["nvidia-smi", "pmon", "-s", "um", "-c", "1"],
            capture_output=True, text=True, timeout=10
        )
    except FileNotFoundError:
        print("[gq] ERROR: nvidia-smi not found. Is the NVIDIA driver installed?",
              file=sys.stderr)
        sys.exit(1)
    except subprocess.TimeoutExpired:
        print("[gq] WARNING: nvidia-smi timed out, treating GPU as busy.",
              file=sys.stderr)
        return False

    if result.returncode != 0:
        print(f"[gq] WARNING: nvidia-smi failed (exit {result.returncode}), "
              "treating GPU as busy.", file=sys.stderr)
        return False

    for line in result.stdout.splitlines():
        if line.startswith("#") or not line.strip():
            continue
        parts = line.split()
        if len(parts) < 2:
            continue
        try:
            pid = int(parts[1])
            if os.stat(f"/proc/{pid}").st_uid == uid:
                return False
        except (ValueError, FileNotFoundError, PermissionError):
            continue
    return True


def _lock_and_read(path: Path, default):
    """Read JSON from path with exclusive lock. Returns default on missing/corrupt."""
    path.touch(exist_ok=True)
    with open(path, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            content = f.read().strip()
            return json.loads(content) if content else default
        except (UnicodeDecodeError, ValueError):
            print(f"[gq] WARNING: {path.name} corrupted, resetting.", file=sys.stderr)
            return default
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


def _lock_and_write(path: Path, data) -> None:
    """Write JSON to path with exclusive lock."""
    path.touch(exist_ok=True)
    with open(path, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            f.seek(0)
            f.write(json.dumps(data, indent=2))
            f.truncate()
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


@contextmanager
def _locked_queue():
    """Hold the lock across a read-modify-write on queue.json.

    Yields the queue list; mutations made in-place are persisted on exit.
    The fcntl lock is held for the whole RMW, so concurrent writers cannot
    lose jobs by interleaving read/write.
    """
    QUEUE_FILE.touch(exist_ok=True)
    with open(QUEUE_FILE, "r+") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            content = f.read().strip()
            try:
                q = json.loads(content) if content else []
            except (UnicodeDecodeError, ValueError):
                print("[gq] WARNING: queue.json corrupted, resetting.",
                      file=sys.stderr)
                q = []
            if not isinstance(q, list):
                print("[gq] WARNING: queue.json corrupted (non-list), resetting.",
                      file=sys.stderr)
                q = []
            yield q
            f.seek(0)
            f.write(json.dumps(q, indent=2))
            f.truncate()
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


def read_queue() -> list:
    q = _lock_and_read(QUEUE_FILE, [])
    if not isinstance(q, list):
        print("[gq] WARNING: queue.json corrupted (non-list), resetting.",
              file=sys.stderr)
        return []
    return q


def write_queue(jobs: list) -> None:
    _lock_and_write(QUEUE_FILE, jobs)


def read_state() -> dict:
    default = {"daemon_pid": None, "running": None}
    state = _lock_and_read(STATE_FILE, default)
    if not isinstance(state, dict):
        print("[gq] WARNING: state.json corrupted (non-object), resetting.", file=sys.stderr)
        return dict(default)
    # Ensure required keys exist even if file had partial data
    return {**default, **state}


def write_state(state: dict) -> None:
    _lock_and_write(STATE_FILE, state)


def _make_job(cmd: str, cwd: str) -> dict:
    return {
        "id": secrets.token_hex(2),
        "cmd": cmd,
        "cwd": cwd,
        "added_at": datetime.datetime.now().isoformat(timespec="seconds"),
    }


def cmd_add(args) -> None:
    job = _make_job(args.command, os.getcwd())
    with _locked_queue() as q:
        q.append(job)
    print(f"[gq] added job {job['id']}: {args.command}")


def cmd_list(args) -> None:
    state = read_state()
    queue = read_queue()

    # Running job
    if state.get("running"):
        r = state["running"]
        try:
            started = datetime.datetime.fromisoformat(r["started_at"])
            elapsed = datetime.datetime.now() - started
            elapsed_str = str(elapsed).split(".")[0]  # drop microseconds
        except (KeyError, ValueError, TypeError):
            elapsed_str = "unknown"
        print("[gq] running:")
        print(f"  {r['id']}  {r['cmd']}   started {elapsed_str} ago")
    else:
        print("[gq] running: none")

    # Pending queue
    n = len(queue)
    label = f"{n} job" + ("s" if n != 1 else "")
    print(f"\n[gq] queue ({label}):")
    if not queue:
        print("  (empty)")
    for i, job in enumerate(queue, 1):
        print(f"  #{i}  {job['id']}  {job['cmd']}")

    # Daemon status
    dpid = state.get("daemon_pid")
    if dpid:
        try:
            os.kill(dpid, 0)
            print(f"\n[gq] daemon: running (pid {dpid})")
        except (ProcessLookupError, TypeError):
            print(f"\n[gq] daemon: stale pid {dpid} (not running)")
    else:
        print("\n[gq] daemon: not running — start with: gq watch")


def cmd_cancel(args) -> None:
    job_id = args.job_id

    # Check if it's the running job (read_state uses its own lock — do NOT
    # hold the queue lock while checking state).
    state = read_state()
    if state.get("running") and state["running"]["id"].startswith(job_id):
        print(f"[gq] job {state['running']['id']} is currently running. "
              "Use Ctrl-C in the gq watch terminal to stop it.")
        return

    with _locked_queue() as q:
        matches = [j for j in q if j["id"].startswith(job_id)]

        if not matches:
            print(f"[gq] job '{job_id}' not found in queue.")
            return
        if len(matches) > 1:
            ids = ", ".join(j["id"] for j in matches)
            print(f"[gq] ambiguous prefix '{job_id}' matches: {ids}. Be more specific.")
            return

        target = matches[0]
        # Mutate the yielded list in place so the RMW persists.
        q[:] = [j for j in q if j["id"] != target["id"]]
    print(f"[gq] cancelled job {target['id']}: {target['cmd']}")


def cmd_clear(args) -> None:
    with _locked_queue() as q:
        n = len(q)
        q[:] = []
    print(f"[gq] cleared {n} pending job{'s' if n != 1 else ''}.")


def _format_elapsed(seconds: float) -> str:
    """Format seconds as HH:MM:SS."""
    s = int(seconds)
    return f"{s // 3600:02d}:{(s % 3600) // 60:02d}:{s % 60:02d}"


def _run_job(job: dict) -> int:
    """
    Run a single job synchronously. stdout/stderr pass through to terminal.
    Returns exit code, or -1 if cwd is missing or launch fails.

    Uses Popen with start_new_session=True so the shell+command form their own
    process group; the real subprocess pid is published to _current_job_pid so
    the SIGINT handler can force-kill the whole group on a second Ctrl-C.
    """
    global _current_job_pid
    cwd = job["cwd"]
    if not os.path.isdir(cwd):
        print(f"[gq] WARNING: cwd '{cwd}' does not exist, skipping job {job['id']}.")
        return -1

    start = time.monotonic()
    print(f"[gq] >>> {job['cmd']}")
    try:
        proc = subprocess.Popen(job["cmd"], shell=True, cwd=cwd,
                                start_new_session=True)
    except Exception as exc:
        print(f"[gq] ERROR running job {job['id']}: {exc}")
        return -1

    _current_job_pid = proc.pid
    # Record the real subprocess pid in state.running so that crash-recovery
    # (cmd_watch) can find and kill the orphan if this daemon is killed mid-job.
    try:
        _state = read_state()
        if _state.get("running") and _state["running"].get("id") == job["id"]:
            _state["running"]["pid"] = proc.pid
            write_state(_state)
    except Exception:
        pass  # best-effort; never let state update break job execution

    try:
        code = proc.wait()
    finally:
        _current_job_pid = None

    elapsed = _format_elapsed(time.monotonic() - start)
    if code == 0:
        print(f"[gq] <<< job {job['id']} DONE (exit=0) in {elapsed}")
    else:
        print(f"[gq] <<< job {job['id']} FAILED (exit={code}) in {elapsed}")
    return code


# Module-level flag so signal handler can communicate with the loop
_shutdown_requested = False
_current_job_pid = None  # type: Optional[int]


def _daemon_loop(poll_interval: int) -> None:
    """Main daemon polling loop. Runs until KeyboardInterrupt or _shutdown_requested."""
    global _shutdown_requested, _current_job_pid
    _shutdown_requested = False

    ctrl_c_count = [0]

    def _handle_sigint(sig, frame):
        ctrl_c_count[0] += 1
        if ctrl_c_count[0] == 1:
            print("\n[gq] Ctrl-C received. Waiting for current job to finish. "
                  "Press Ctrl-C again to force-kill.", file=sys.stderr)
            _shutdown_requested = True  # will exit after current job
        else:
            # Second Ctrl-C: force-kill the whole process group. shell=True
            # spawns /bin/sh -c <cmd>, so killing only the shell pid would
            # orphan the real command; SIGKILL the group via os.killpg instead.
            pid = _current_job_pid
            if pid is not None:
                try:
                    os.killpg(os.getpgid(pid), signal.SIGKILL)
                except ProcessLookupError:
                    pass
            sys.exit(0)

    old_handler = signal.signal(signal.SIGINT, _handle_sigint)
    try:
        while not _shutdown_requested:
            state = read_state()

            # Skip if a job is actively tracked (shouldn't happen in synchronous mode,
            # but guards against stale state)
            if state.get("running"):
                time.sleep(poll_interval)
                continue

            if not gpu_is_idle():
                time.sleep(poll_interval)
                continue

            # Pop a job atomically: hold the lock across the RMW so a
            # concurrent cmd_add cannot be lost.
            job = None
            with _locked_queue() as q:
                if q:
                    job = q.pop(0)
            if job is None:
                time.sleep(poll_interval)
                continue

            job["started_at"] = datetime.datetime.now().isoformat(timespec="seconds")
            # pid placeholder; _run_job fills in the real subprocess pid once
            # Popen starts, so crash-recovery (cmd_watch) can find/kill it.
            write_state({
                "daemon_pid": os.getpid(),
                "running": {**job, "pid": None},
            })

            print(f"\n[gq] GPU idle — starting job {job['id']}")
            _run_job(job)  # blocks until done

            write_state({"daemon_pid": os.getpid(), "running": None})

            if _shutdown_requested:
                break
    finally:
        signal.signal(signal.SIGINT, old_handler)

    print("[gq] daemon exiting.")


def cmd_watch(args) -> None:
    # Check for existing daemon
    state = read_state()
    dpid = state.get("daemon_pid")
    if dpid:
        try:
            os.kill(dpid, 0)
            print(f"[gq] daemon already running (pid {dpid}). Exiting.")
            return
        except ProcessLookupError:
            pass  # stale pid — proceed

    # Clear stale running entry on startup (crash recovery). If the recorded
    # pid is still alive, the previous daemon was killed mid-job and the
    # orphan is still on the GPU — kill its process group, then clear.
    running = state.get("running")
    if running:
        rpid = running.get("pid")
        alive = False
        if rpid:
            try:
                # Job runs in its own session/group (start_new_session=True),
                # so getpgid(rpid) == rpid. Check liveness via the group.
                os.killpg(os.getpgid(rpid), 0)
                alive = True
            except ProcessLookupError:
                pass
            except (TypeError, PermissionError):
                pass  # pid None/non-int or not ours — treat as stale
        if not alive:
            print(f"[gq] WARNING: stale running entry for job {running.get('id')} "
                  "cleared (process no longer running).", file=sys.stderr)
            state["running"] = None
        else:
            print(f"[gq] WARNING: orphaned job {running.get('id')} (pid {rpid}) still "
                  "running from a previous daemon crash; killing its process group.",
                  file=sys.stderr)
            try:
                os.killpg(os.getpgid(rpid), signal.SIGKILL)
            except ProcessLookupError:
                pass
            state["running"] = None

    # Register this daemon
    state["daemon_pid"] = os.getpid()
    write_state(state)

    print(f"[gq] daemon started (pid {os.getpid()}), polling every {args.poll}s")
    print("[gq] Ctrl-C to stop gracefully. Press twice to force-kill.\n")

    try:
        _daemon_loop(args.poll)
    finally:
        # Clean up daemon_pid on exit, and clear any running entry left by a
        # force-kill mid-job (graceful exits already set running=None).
        s = read_state()
        s["daemon_pid"] = None
        s["running"] = None
        write_state(s)


def main():
    parser = argparse.ArgumentParser(
        prog="gq", description="GPU Task Queue — run jobs when GPU is free"
    )
    sub = parser.add_subparsers(dest="cmd")
    sub.required = True

    p_watch = sub.add_parser("watch", help="Start the daemon (run in tmux)")
    p_watch.add_argument("--poll", type=int, default=15,
                         help="Poll interval in seconds (default: 15)")

    p_add = sub.add_parser("add", help="Add a command to the queue")
    p_add.add_argument("command", help="Shell command to run")

    sub.add_parser("list", help="Show queue and current status")

    p_cancel = sub.add_parser("cancel", help="Remove a pending job by ID or prefix")
    p_cancel.add_argument("job_id", help="Job ID or unique prefix")

    sub.add_parser("clear", help="Clear all pending jobs")

    args = parser.parse_args()
    QUEUE_DIR.mkdir(parents=True, exist_ok=True)

    dispatch = {
        "watch": cmd_watch,
        "add": cmd_add,
        "list": cmd_list,
        "cancel": cmd_cancel,
        "clear": cmd_clear,
    }
    dispatch[args.cmd](args)


if __name__ == "__main__":
    main()
